generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Signature {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  template  String
  data      Json
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Asset {
  id        String   @id @default(cuid())
  key       String   @unique
  url       String
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

# Postgres (Railway provides DATABASE_URL automatically when linked)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# S3 / S3-compatible storage (Railway Bucket exposes these)
AWS_ENDPOINT_URL="https://s3.example.com"
AWS_S3_BUCKET_NAME="my-bucket"
AWS_DEFAULT_REGION="auto"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Optional: public CDN/host base for serving uploaded images.
# If unset, uploads are served through the in-app /i/<key> proxy so private
# buckets work without needing object-level public-read ACLs.
S3_PUBLIC_BASE_URL=""

# Optional: public app URL for share links (defaults to request origin).
NEXT_PUBLIC_APP_URL=""
